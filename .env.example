# DEEPSEEK_API_KEY: Required for DeepSeek API calls via OpenAI-compatible endpoint.
# Get your key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"

# DEEPSEEK_BASE_URL: Optional override for DeepSeek-compatible endpoints.
# Default: https://api.deepseek.com/v1
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# MP_API_KEY: Required for Materials Project API calls.
# Get your key at https://next-gen.materialsproject.org/api
MP_API_KEY="YOUR_MP_API_KEY"
